<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Broken ring, gradient teal -> amber, rotated so the gap reads as an opening -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="-45">
        <path
            android:pathData="M54,27 A27,27 0 1 1 27,54"
            android:fillColor="#00000000"
            android:strokeWidth="11"
            android:strokeLineCap="round"
            android:strokeAlpha="1">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="20"
                    android:startY="20"
                    android:endX="88"
                    android:endY="88"
                    android:startColor="#5BE8D0"
                    android:centerColor="#37C6B0"
                    android:endColor="#F0A94E" />
            </aapt:attr>
        </path>
    </group>

    <!-- Amber dot centered in the gap -->
    <path
        android:pathData="M54,47 A7,7 0 1 1 53.99,47 Z"
        android:fillColor="#F0A94E" />

</vector>
