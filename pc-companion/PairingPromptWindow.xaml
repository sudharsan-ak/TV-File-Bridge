<Window x:Class="PcCompanion.PairingPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pair device?" Height="180" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="A new device wants to connect" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" x:Name="DeviceLabelText" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="2" Text="Allow it to send clipboard items to this PC?" TextWrapping="Wrap" Foreground="Gray"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Deny" Width="90" Margin="0,0,8,0" Click="OnDenyClick"/>
            <Button Content="Allow" Width="90" IsDefault="True" Click="OnAllowClick"/>
        </StackPanel>
    </Grid>
</Window>
